APP_NAME=RAG_Bot
APP_ENV=dev

# LLM config (OpenAI-compatible API)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SEC=30

# RAG config
RAG_TOP_K=3
RAG_CANDIDATE_K=8
RAG_MAX_RETRIEVAL_DISTANCE=1.25
RAG_MIN_CHUNK_CHARS=20
RAG_ENABLE_DUAL_ROUTE_RETRIEVAL=true
RETRIEVER_MODE=chroma
ENABLE_QUERY_REWRITE=false
QUERY_REWRITE_MODE=none
QUERY_REWRITE_MAX_CHARS=256
QUERY_REWRITE_CACHE_ENABLED=true
QUERY_REWRITE_CACHE_TTL_SEC=900
QUERY_REWRITE_CACHE_MAX_SIZE=512
CHAT_HISTORY_ENABLED=true
CHAT_HISTORY_DB_PATH=data/chat_history/chat_history.db
ENABLE_HISTORY_CONTEXT=true
HISTORY_CONTEXT_MAX_MESSAGES=8
ENABLE_HISTORY_QUESTION_REWRITE=true
HISTORY_ENFORCE_USER_SCOPE=true
HISTORY_ADMIN_TOKEN=

# Batch vectorization / ingestion
KNOWLEDGE_BASE_DIR=data/knowledge_base
KNOWLEDGE_BASE_EXTENSIONS=[".txt",".md",".pdf",".doc",".docx",".xlsx",".csv",".json"]
PDF_OCR_FALLBACK_ENABLED=true
PDF_TEXT_MIN_CHARS=30
PDF_OCR_ENGINE=tesseract
PDF_OCR_LANG=chi_sim+eng
PDF_OCR_DPI=200
PDF_OCR_MAX_PAGES=0
PDF_OCR_TESSERACT_CMD=
CHUNK_MODE=hybrid
INGEST_CHUNK_SIZE=800
INGEST_CHUNK_OVERLAP=120
INGEST_PARENT_CHUNK_SIZE=2000
INGEST_MANIFEST_PATH=data/vector_store/ingest_manifest.json
INGEST_ENABLE_INCREMENTAL=true

# MMR (Maximal Marginal Relevance) retrieval
ENABLE_MMR=false
MMR_LAMBDA=0.5

# CRAG (Corrective RAG) post-retrieval
ENABLE_CRAG=false
CRAG_MAX_RETRIES=1
CRAG_CORRECT_THRESHOLD=0.5

# Cross-Encoder Reranking (requires sentence-transformers)
ENABLE_CROSS_ENCODER_RERANKER=false
CROSS_ENCODER_MODEL=BAAI/bge-reranker-v2-m3
CROSS_ENCODER_TOP_N=5

# HyDE (Hypothetical Document Embeddings)
ENABLE_HYDE=false

# Embedding deduplication
EMBEDDING_DEDUP_THRESHOLD=0.95

# Structured output (table/list auto-detection)
ENABLE_STRUCTURED_OUTPUT=true

# Embedding config
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_TIMEOUT_SEC=30
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=32

# Vector store config
VECTOR_STORE_MODE=chroma
VECTOR_STORE_COLLECTION=rag_kb_default
CHROMA_PERSIST_DIR=data/vector_store/chroma
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_TIMEOUT_SEC=30

# Optional: "http://localhost:3000,http://127.0.0.1:3000"
ALLOW_CORS_ORIGINS=["*"]

# Reserved for enterprise WeChat integration
WECHAT_TOKEN=
WECHAT_AES_KEY=
WECHAT_CORP_ID=
